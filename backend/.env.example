PORT=5000
AWS_REGION=us-east-1

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# DynamoDB Tables
DYNAMO_USERS_TABLE=MiniJira-Users
DYNAMO_TEAMS_TABLE=MiniJira-Teams
DYNAMO_PROJECTS_TABLE=MiniJira-Projects
DYNAMO_TASKS_TABLE=MiniJira-Tasks
DYNAMO_COMMENTS_TABLE=MiniJira-Comments
DYNAMO_AUDIT_TABLE=MiniJira-AuditLogs

# S3
S3_ORIGINALS_BUCKET=mini-jira-originals
S3_RESIZED_BUCKET=mini-jira-resized

# SNS
SNS_TASK_ASSIGNMENT_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:MiniJira-TaskAssignment
SNS_ALERTS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:MiniJira-Alerts

# SQS
SQS_ASSIGNMENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/MiniJira-AssignmentQueue

# Frontend URL (for CORS)
FRONTEND_URL=https://your-cloudfront-url.cloudfront.net
